# ── SendGrid ────────────────────────────────────────────────────────
# Required. Obtain from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Verified sender identity in your SendGrid account
SENDGRID_FROM_EMAIL=noreply@deviare.africa
SENDGRID_FROM_NAME=Deviare Customer Success

# ── Server ──────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Dev default: http://localhost:5173 (Vite)
# Production: set to the real frontend URL, e.g. https://pulse.deviare.africa
ALLOWED_ORIGINS=http://localhost:5173

# ── Database ────────────────────────────────────────────────────────
# Optional. Defaults to ./data/pulse_email.db
# DB_PATH=./data/pulse_email.db
